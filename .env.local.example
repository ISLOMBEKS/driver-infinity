# Public URL of your deployed app (no trailing slash)
NEXT_PUBLIC_URL=https://your-app.railway.app

# Your wallet address that receives the $0.10 USDC continue payments
NEXT_PUBLIC_GAME_WALLET=0xYourWalletAddressHere

# Optional: OnchainKit API key (get free at portal.cdp.coinbase.com)
NEXT_PUBLIC_ONCHAINKIT_API_KEY=
